{
  "name": "daily-overview",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "bash scripts/dev-clean.sh",
    "dev:snapshot": "DASHBOARD_DATA_MODE=snapshot npm run dev:clean",
    "build": "next build",
    "build:snapshot": "DASHBOARD_DATA_MODE=snapshot npm run build",
    "build:static-prep": "npm run generate:snapshot && DASHBOARD_DATA_MODE=snapshot npm run build",
    "start": "next start",
    "lint": "eslint",
    "import:food-drink": "node scripts/import-capacities-food-drink.mjs data/food-drink.capacities.import.json",
    "generate:snapshot": "node --experimental-strip-types --loader ./scripts/ts-alias-loader.mjs scripts/generate-dashboard-snapshot.ts",
    "send:daily-email": "node --experimental-strip-types --loader ./scripts/ts-alias-loader.mjs scripts/send-daily-email.ts"
  },
  "dependencies": {
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "typescript": "^5"
  }
}
